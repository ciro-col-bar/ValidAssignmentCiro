# Pre-Viz Engine — Test Automation Environment Variables
# Copy this file to .env and fill in values. Never commit .env to version control.

# Target environment: staging | production
ENVIRONMENT=staging

# Override base URL (optional — defaults to the value in config/environments.js)
BASE_URL=https://previz-engine-m1mm9ayva-valid.vercel.app

# Allure results output directory
ALLURE_RESULTS_DIR=./reports/allure-results

# Set to 'true' to skip tests tagged @api-dependent (use in dry-run / offline CI)
SKIP_API_TESTS=false

# Optional: production base URL (used when ENVIRONMENT=production)
# PROD_BASE_URL=https://your-production-url.vercel.app
